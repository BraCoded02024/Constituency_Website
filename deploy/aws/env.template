# Copy to backend/.env on your EC2 instance:
#   cp deploy/aws/env.template backend/.env
#   nano backend/.env

PORT=5001
JWT_SECRET=change-me-use-a-long-random-string
ADMIN_EMAIL=admin@yourdomain.gov.gh
ADMIN_PASSWORD=change-me-strong-password

# Supabase (recommended) — Project Settings → Database → URI (Session pooler)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Optional: persistent uploads path on EC2 (default: backend/uploads)
# UPLOADS_DIR=/var/www/constituency/uploads
