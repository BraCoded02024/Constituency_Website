PORT=5001
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@constituency.gov.gh
ADMIN_PASSWORD=change-me-in-production

# ── Supabase (PostgreSQL) ──────────────────────────────────────────────
# Dashboard: Project Settings → Database → Connection string → URI
#
# Local dev + Vercel: use Supabase "Session pooler" (port 5432) or "Transaction pooler" (port 6543)
# Copy the full URI and paste below (replace [YOUR-PASSWORD] if shown as placeholder)
#
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#
# Optional alias (same value as DATABASE_URL):
# SUPABASE_DB_URL=

# ── Cloudinary (recommended on Vercel — persistent image storage) ─────
# cloudinary.com → Dashboard → Product environment credentials
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend (Vercel → Environment Variables):
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# Optional full URLs after uploading branding images:
# NEXT_PUBLIC_NPP_FLAG_URL=https://res.cloudinary.com/...
# NEXT_PUBLIC_HERO_ELEPHANT_URL=https://res.cloudinary.com/...
